{
  "name": "printer-proxy-installer",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build:macos-arm64": "bun build --compile --minify --target=bun-darwin-arm64 src/index.ts --outfile dist/printer-proxy-setup-macos-arm64",
    "build:macos-x64": "bun build --compile --minify --target=bun-darwin-x64 src/index.ts --outfile dist/printer-proxy-setup-macos-x64",
    "build:windows": "bun build --compile --minify --target=bun-windows-x64 src/index.ts --outfile dist/printer-proxy-setup.exe",
    "build:all": "bun run build:macos-arm64 && bun run build:macos-x64 && bun run build:windows"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.11"
  }
}
